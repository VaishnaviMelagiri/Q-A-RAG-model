# Copy this file to `.env` and fill in real values. `.env` is git-ignored — never commit it.
# Load it into your shell before running the app:  set -a && source .env && set +a
# (Spring Boot does NOT read .env; the vars must be EXPORTED so the app's JVM inherits them.)

# --- Mistral API (active provider for embeddings + generation) ---
# Get a key at https://console.mistral.ai/api-keys
export MISTRAL_API_KEY=your-mistral-api-key-here

# --- Google Gemini API (optional; only if you switch rag.embedding.provider back to gemini) ---
# export GEMINI_API_KEY=your-gemini-api-key-here

# --- Postgres / pgvector (must match docker-compose.yml) ---
POSTGRES_DB=ragdb
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_local_pw
POSTGRES_PORT=5432
