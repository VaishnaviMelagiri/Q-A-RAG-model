# Registers a startup FailureAnalyzer so a missing/unresolved provider API key (e.g.
# MISTRAL_API_KEY) produces a clean "APPLICATION FAILED TO START" message instead of a raw
# bean-instantiation stack trace.
org.springframework.boot.diagnostics.FailureAnalyzer=\
com.qacopilot.embedding.MissingApiKeyFailureAnalyzer
